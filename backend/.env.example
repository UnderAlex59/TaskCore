DATABASE_URL=postgresql+asyncpg://app_user:app_pass@localhost:5432/taskplatform
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
ALLOWED_ORIGINS=["http://localhost:5173"]
CHAT_AGENT_MODULES=[]
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://localhost:11434

# LLM providers and agent routing are configured in the admin panel.
# Embeddings are configured explicitly through .env.
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
LLM_SETTINGS_ENCRYPTION_KEY=replace_with_a_separate_runtime_secret
RAG_CHUNK_TARGET_TOKENS=450
RAG_CHUNK_OVERLAP_TOKENS=50
RAG_ATTACHMENT_MAX_TEXT_CHARS=20000
RAG_VISION_ENABLED=true
RAG_VISION_MAX_IMAGE_BYTES=5242880
UPLOAD_DIR=/var/lib/task-platform/uploads
