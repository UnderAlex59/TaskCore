DATABASE_URL=postgresql+asyncpg://app_user:app_pass@postgres:5432/taskplatform
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=task-platform.ru

ALLOWED_ORIGINS=["https://task-platform.ru"]
CHAT_AGENT_MODULES=[]

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

OPENAI_API_KEY=
OPENAI_BASE_URL=

OLLAMA_BASE_URL=http://ollama:11434
GIGACHAT_VERIFY_SSL=true
GIGACHAT_CA_BUNDLE_FILE=/etc/ssl/certs/russian_trusted_root_ca_pem.crt
GIGACHAT_CA_BUNDLE_PEM=
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
LLM_SETTINGS_ENCRYPTION_KEY=replace_with_a_second_long_random_secret

RAG_CHUNK_TARGET_TOKENS=450
RAG_CHUNK_OVERLAP_TOKENS=50
RAG_ATTACHMENT_MAX_TEXT_CHARS=20000
RAG_VISION_ENABLED=true
RAG_VISION_MAX_IMAGE_BYTES=5242880

UPLOAD_DIR=/var/lib/task-platform/uploads
